#: blog/views.py:899
#, python-format
msgid ""
"dostali sme žiadosť o odstránenie vášho účtu. V prípade chyby máte 30 dní "
"možnosť prihlásiť sa.\n"
"\n"
"http://127.0.0.1:8000/%(language)s/prihlasenie/\n"
"\n"
"V opačnom prípade bude váš účet neodvratne odstránený.\n"
"Tím Street Workout Žilina."
msgstr ""
"hemos recibido una solicitud para eliminar su cuenta. En caso de error, "
"tiene 30 días para iniciar sesión.\n"
"\n"
"http://127.0.0.1:8000/%(language)s/acceso/\n"
"\n"
"De lo contrario, su cuenta será eliminada permanentemente.\n"
"Equipo Street Workout Žilina."

#: blog/views.py:900
#, python-format
msgid ""
"dostali sme žiadosť o odstránenie vášho účtu. V prípade chyby máte 30 dní "
"možnosť <a href=\"http://127.0.0.1:8000/%(language)s/prihlasenie/\" "
"title=\"Prihlásiť sa\" target=\"_blank\">prihlásiť sa</a>. V opačnom prípade "
"bude váš účet neodvratne odstránený."
msgstr ""
"hemos recibido una solicitud para eliminar su cuenta. En caso de error, "
"tiene 30 días para <a href=\"http://127.0.0.1:8000/%(language)s/acceso/\" "
"title=\"Acceso\" target=\"_blank\">iniciar sesión</a>. De lo contrario, su "
"cuenta será eliminada permanentemente."

#: blog/views.py:901
msgid "Tento e-mail prosím ignorujte, slúži len pre Vaše informovanie."
msgstr ""
"Por favor, ignore este correo electrónico; es solo para su información."

