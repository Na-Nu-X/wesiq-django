#: blog/views.py:806
msgid "Boli ste odhlásený"
msgstr "Vous avez été déconnecté"

#: blog/views.py:899
#, python-format
msgid ""
"dostali sme žiadosť o odstránenie vášho účtu. V prípade chyby máte 30 dní "
"možnosť prihlásiť sa.\n"
"\n"
"http://127.0.0.1:8000/%(language)s/prihlasenie/\n"
"\n"
"V opačnom prípade bude váš účet neodvratne odstránený.\n"
"Tím Street Workout Žilina."
msgstr ""
"nous avons reçu une demande de suppression de votre compte. En cas d'erreur, "
"vous disposez de 30 jours pour vous connecter.\n"
"\n"
"http://127.0.0.1:8000/%(language)s/se-connecter/\n"
"\n"
"Passé ce délai, votre compte sera définitivement supprimé.\n"
"Équipe Street Workout Žilina."

#: blog/views.py:900
#, python-format
msgid ""
"dostali sme žiadosť o odstránenie vášho účtu. V prípade chyby máte 30 dní "
"možnosť <a href=\"http://127.0.0.1:8000/%(language)s/prihlasenie/\" "
"title=\"Prihlásiť sa\" target=\"_blank\">prihlásiť sa</a>. V opačnom prípade "
"bude váš účet neodvratne odstránený."
msgstr ""
"nous avons reçu une demande de suppression de votre compte. En cas d'erreur, "
"vous disposez de 30 jours pour vous <a href=\"http://"
"127.0.0.1:8000/%(language)s/se-connecter/\" title=\"Se connecter\" "
"target=\"_blank\">connecter</a>. Passé ce délai, votre compte sera "
"définitivement supprimé."

#: blog/views.py:901
msgid "Tento e-mail prosím ignorujte, slúži len pre Vaše informovanie."
msgstr "Ak neviete, aký je váš e-mail, kontaktujte nás pre viac informácií."

